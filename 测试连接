"""快速诊断 DeepSeek API 连接"""
import httpx
from openai import OpenAI

API_KEY = "sk-516b1fd3acf441f9ba974daaff44a88f"
BASE_URL = "https://api.deepseek.com"

# ① 最底层：直接 HTTP 请求
print("=" * 50)
print("测试 1：直接 HTTPS 请求 api.deepseek.com")
print("=" * 50)
try:
    r = httpx.get(f"{BASE_URL}/v1/models",
                  headers={"Authorization": f"Bearer {API_KEY}"},
                  timeout=15)
    print(f"  状态码: {r.status_code}")
    print(f"  响应: {r.text[:200]}")
except Exception as e:
    print(f"  ❌ 失败: {type(e).__name__}: {e}")

# ② 通过 OpenAI SDK
print("\n" + "=" * 50)
print("测试 2：通过 OpenAI SDK 调用")
print("=" * 50)
try:
    client = OpenAI(api_key=API_KEY, base_url=BASE_URL, timeout=15)
    resp = client.chat.completions.create(
        model="deepseek-chat",
        messages=[{"role": "user", "content": "说'连接成功'两个字"}],
        max_tokens=10,
    )
    print(f"  ✅ 成功: {resp.choices[0].message.content}")
except Exception as e:
    print(f"  ❌ 失败: {type(e).__name__}: {e}")

# ③ 如果你用了代理，试试带代理
print("\n" + "=" * 50)
print("测试 3：检测系统代理环境变量")
print("=" * 50)
import os
for k in ["HTTP_PROXY", "HTTPS_PROXY", "http_proxy", "https_proxy", "ALL_PROXY", "NO_PROXY"]:
    v = os.environ.get(k, "")
    if v:
        print(f"  {k} = {v}")
if not any(os.environ.get(k) for k in ["HTTP_PROXY", "HTTPS_PROXY", "http_proxy", "https_proxy"]):
    print("  （未检测到代理环境变量）")
    print("  💡 如果你在用 Clash/V2Ray 等代理，试试设置：")
    print('     $env:HTTPS_PROXY="http://127.0.0.1:7890"')
    print("     然后重新运行")